# Server
DATABASE_URL=postgresql://user:password@host:5432/notes
JWT_SECRET=change-me-to-a-long-random-string
CLIENT_URLS=https://yourdomain.com
NODE_ENV=production

# Client (Vite — must be VITE_ prefixed)
VITE_ONESIGNAL_APP_ID=your-onesignal-app-id
VITE_API_BASE_URL=/api
VITE_SOCKET_URL=/
VITE_GITHUB_REPO=prdxqcy/NoteFlow
VITE_DESKTOP_DOWNLOAD_URL=https://github.com/prdxqcy/NoteFlow/releases/latest
